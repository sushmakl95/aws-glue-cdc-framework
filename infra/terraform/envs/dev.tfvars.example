environment              = "dev"
aws_region               = "ap-south-1"
project_prefix           = "cdc-framework"
vpc_cidr                 = "10.20.0.0/16"

# Enable sinks individually — disable any to save cost
enable_redshift   = true
enable_postgres   = true
enable_opensearch = false  # OpenSearch is the most expensive; dev defaults to off

# Capacity (keep small in dev)
kinesis_shard_count      = 1
redshift_node_type       = "dc2.large"
redshift_node_count      = 1
postgres_instance_class  = "db.t3.small"
opensearch_instance_type = "t3.small.search"
glue_worker_type         = "G.1X"
glue_number_of_workers   = 3

# Schedule
pipeline_schedule        = "rate(30 minutes)"

# Alerts
alarm_email              = "your-email@example.com"
