# Copy to .env (gitignored) and fill in local values.

# AWS
AWS_PROFILE=mensa
AWS_REGION=ap-south-1

# Pipeline env selector
PIPELINE_ENV=local

# S3 paths (prod only)
STAGING_BUCKET=cdc-glue-staging-prod-xxxxx
REDSHIFT_IAM_ROLE_ARN=arn:aws:iam::123456789012:role/cdc-glue-redshift-prod
OPENSEARCH_ENDPOINT=search-cdc-glue-xxx.ap-south-1.es.amazonaws.com

# Local MySQL (Docker Compose)
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=debezium
MYSQL_PASSWORD=dbz

# Local Kafka Connect
KAFKA_CONNECT_URL=http://localhost:8083
